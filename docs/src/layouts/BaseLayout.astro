---
import '../styles/globals.css';
import Analytics from '../components/Analytics.astro';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'blazor-mudblazor-starter | Material Dark Studio',
  description = 'Production-ready Blazor Server starter template with MudBlazor Material Design components, .NET 9, Docker, and Azure deployment. Get your Blazor app running in minutes.'
} = Astro.props;

const pageUrl = Astro.site ? new URL(Astro.url.pathname, Astro.site).href : `https://jonathanperis.github.io${Astro.url.pathname}`;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareSourceCode',
  'name': 'Blazor MudBlazor Starter',
  'description': description,
  'url': pageUrl,
  'applicationCategory': 'DeveloperApplication',
  'operatingSystem': 'Web',
  'codeRepository': 'https://github.com/jonathanperis/blazor-mudblazor-starter',
  'programmingLanguage': 'C#',
  'license': 'https://github.com/jonathanperis/blazor-mudblazor-starter/blob/main/LICENSE',
  'author': {
    '@type': 'Person',
    'name': 'Jonathan Peris',
    'url': 'https://jonathanperis.github.io/'
  }
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=DM+Mono:ital,wght@0,300;0,400;0,500;1,300;1,400;1,500&family=DM+Sans:ital,opsz,wght@0,9..40,100..1000;1,9..40,100..1000&display=swap" rel="stylesheet" />
    <meta name="description" content={description} />
    <meta name="keywords" content="Blazor, MudBlazor, .NET 9, Material Design, Azure, Docker, C#, Blazor Server, starter template" />
    <link rel="canonical" href={pageUrl} />
    <meta name="theme-color" content="#7e57c2" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={pageUrl} />
    <meta property="og:site_name" content="blazor-mudblazor-starter" />
    <meta property="og:locale" content="en_US" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:creator" content="@jperis_silva" />

    <!-- JSON-LD Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

    <title>{title}</title>
    <Analytics />
  </head>
  <body>

    <div class="particles">
      <div class="particle"></div>
      <div class="particle"></div>
      <div class="particle"></div>
      <div class="particle"></div>
      <div class="particle"></div>
      <div class="particle"></div>
    </div>

    <div class="glow"></div>

    <slot />
  </body>
</html>
